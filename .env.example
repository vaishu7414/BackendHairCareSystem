# Backend Environment Variables - Example
# Copy this to your deployment platform's environment variables section

# === Database Configuration ===
# For Railway with MySQL
SPRING_DATASOURCE_URL=mysql://railwayuser:password@containers-us-west-XXX.railway.app:PORT/railway
SPRING_DATASOURCE_USERNAME=railwayuser
SPRING_DATASOURCE_PASSWORD=your_secure_password_here
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# For Render with PlanetScale
# SPRING_DATASOURCE_URL=mysql://username:password@aws.connect.psdb.cloud/haircare_db?sslMode=VERIFY_IDENTITY
# SPRING_DATASOURCE_USERNAME=username
# SPRING_DATASOURCE_PASSWORD=password

# For Render with PostgreSQL
# SPRING_DATASOURCE_URL=postgresql://user:password@localhost:5432/haircare_db
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# === JPA/Hibernate Configuration ===
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect

# === Server Configuration ===
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# === JWT Configuration ===
JWT_SECRET=your_super_secret_key_here_at_least_32_characters_long_and_random
JWT_EXPIRATION=86400000

# === Mail Configuration (Gmail) ===
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_gmail@gmail.com
SPRING_MAIL_PASSWORD=your_app_specific_password_16chars
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# === CORS Configuration ===
FRONTEND_URL=https://your-frontend-domain.vercel.app

# === Logging ===
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_HAIRCARE_ECOMMERCE=DEBUG
